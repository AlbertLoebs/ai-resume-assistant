# Backend env vars — copy this file to .env (gitignored) and fill in real values,
# or set them directly in your IntelliJ run configuration's Environment variables.

# Base64-encoded 256-bit secret used to sign JWTs.
# Generate one with PowerShell:
#   $b = New-Object byte[] 32
#   [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b)
#   [Convert]::ToBase64String($b)
JWT_SECRET=replace-with-base64-encoded-256-bit-key
